
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String     @id @default(uuid())
  email String  @unique
  name  String
  password String
  RA String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}