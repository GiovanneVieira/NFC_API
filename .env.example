# ── APLICAÇÃO ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── BANCO DE DADOS ─────────────────────────────────────
# Desenvolvimento (Docker):  postgresql://admin:admin@localhost:5432/nfc_local_db?schema=public
# Produção (Neon Cloud):     postgresql://<user>:<pass>@<host>/<db>?sslmode=require
DATABASE_URL=

# ── AUTENTICAÇÃO (BETTER-AUTH) ─────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── INFRAESTRUTURA ─────────────────────────────────────
# Desenvolvimento (Docker):  redis://localhost:6379
# Produção:                  redis://<host>:6379
REDIS_URL=

# Desenvolvimento (Docker):  mqtt://localhost:1883
# Produção:                  mqtt://<host>:1883
MQTT_BROKER_URL=