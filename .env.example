# ── APLICAÇÃO ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── BANCO DE DADOS ─────────────────────────────────────
# Desenvolvimento (Docker):  postgresql://admin:admin@localhost:5432/nfc_local_db?schema=public
# Produção (Neon Cloud):     postgresql://<user>:<pass>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://admin:admin@localhost:5432/nfc_local_db?schema=public"

# ── AUTENTICAÇÃO (BETTER-AUTH) ─────────────────────────
# Gere um segredo forte: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Origens confiáveis para o better-auth (CSRF) — separado por vírgula.
# Inclua a origem do app Expo (web) e a própria API.
TRUSTED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ── CORS (app Expo) ────────────────────────────────────
# Origens liberadas no CORS da API. Vazio = libera todas (apenas dev).
# Em produção defina as origens explícitas, ex.: https://app.suaescola.com
CORS_ORIGINS=

# ── INFRAESTRUTURA ─────────────────────────────────────
# Desenvolvimento (Docker):  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Desenvolvimento (Docker):  mqtt://localhost:1883
MQTT_BROKER_URL=mqtt://localhost:1883
